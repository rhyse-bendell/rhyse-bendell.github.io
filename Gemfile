source "https://rubygems.org"

# Keep Jekyll on the 4.3 line for broad plugin compatibility in CI.
gem "jekyll", "~> 4.3.3"
gem "webrick", "~> 1.8"

# al-folio uses a remote theme plus a broad plugin set.
group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-include-cache"
  gem "jekyll-scholar"
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-archives"
  gem "jekyll-email-protect"
  gem "jekyll-get-json"
  gem "jekyll-imagemagick"
  gem "jekyll-link-attributes"
  gem "jekyll-loading-lazy"
  gem "jekyll-optional-front-matter"
  gem "jekyll-paginate-v2"
  gem "jekyll-regex-replace"
  gem "jekyll-tabs"
  gem "jekyll-toc"
  gem "jemoji"
  gem "jekyll-socials"
end
